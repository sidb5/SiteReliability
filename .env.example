# =============================================================================
# Watchdog — Environment Configuration
# Copy this file to .env and fill in all values before starting the server.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# Default: SQLite file in project root. For production, use PostgreSQL.
# Example PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/watchdog
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./watchdog.db

# -----------------------------------------------------------------------------
# JWT (RS256 asymmetric signing)
# Generate keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then base64-encode each file and paste here (no newlines):
#   python -c "import base64; print(base64.b64encode(open('private.pem','rb').read()).decode())"
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY=REPLACE_WITH_BASE64_ENCODED_RSA_PRIVATE_KEY_PEM
JWT_PUBLIC_KEY=REPLACE_WITH_BASE64_ENCODED_RSA_PUBLIC_KEY_PEM

# JWT token lifetimes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Fernet encryption key (for webhook secrets and DB connection strings at rest)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED. Must be a valid Fernet key (32 bytes, URL-safe base64-encoded).
# -----------------------------------------------------------------------------
FERNET_KEY=REPLACE_WITH_FERNET_KEY

# -----------------------------------------------------------------------------
# Platform Admin bootstrap credentials
# Used on first startup to create the Platform Admin account.
# Change the password immediately after first login.
# REQUIRED.
# -----------------------------------------------------------------------------
PLATFORM_ADMIN_EMAIL=admin@watchdog.local
PLATFORM_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# Application settings
# -----------------------------------------------------------------------------
APP_VERSION=1.0.0

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Production default: WARNING (anomalies, errors, connector failures only)
LOG_LEVEL=WARNING

# CORS origins (comma-separated list or JSON array)
# Example: ["https://app.example.com","https://admin.example.com"]
CORS_ORIGINS=["http://localhost:8000"]

# -----------------------------------------------------------------------------
# Rate limiting (slowapi)
# Format: "<count>/<period>" — period: second | minute | hour
# -----------------------------------------------------------------------------
RATE_LIMIT_INGEST=100/minute
RATE_LIMIT_AUTH=10/minute

# -----------------------------------------------------------------------------
# Connector observer backend (watchdog library)
# Options: polling (default, cross-platform) | auto (watchdog chooses — inotify
#          on Linux, ReadDirectoryChangesW on Windows, kqueue on macOS)
# Use polling in all environments unless you have a specific reason to change it.
# -----------------------------------------------------------------------------
CONNECTOR_OBSERVER=polling

# -----------------------------------------------------------------------------
# Cache backend
# Options: memory (default, zero deps) | redis
# -----------------------------------------------------------------------------
CACHE_BACKEND=memory

# Redis URL (only required when CACHE_BACKEND=redis)
# REDIS_URL=redis://localhost:6379/0
